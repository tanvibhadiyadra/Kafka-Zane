# ─────────────────────────────────────────────────────────────────────────────
#  QueryGuard – Environment Variables
#  Copy to .env and fill in your real values before running docker compose up.
#  Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# For Neon (recommended for production):
#   postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
# For local docker postgres (--profile local-db):
#   postgresql://qguser:qgpass@localhost:5432/queryguard
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Only needed when using --profile local-db (local postgres container)
POSTGRES_USER=qguser
POSTGRES_PASSWORD=qgpass
POSTGRES_DB=queryguard

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_TENANT_TTL_SECONDS=0        # Seconds; use 0 for persistent keys (no expiry)

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Overridden to kafka:29092 inside Docker containers automatically.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_GITHUB_EVENTS=github-events
KAFKA_TOPIC_DLQ=github-events-dlq
KAFKA_CONSUMER_GROUP=queryguard-workers
KAFKA_MAX_RETRIES=3
KAFKA_ENABLED=true                   # Set to false to skip Kafka (smoke test only)

# ── GitHub App ────────────────────────────────────────────────────────────────
# From your GitHub App settings page:
GITHUB_APP_ID=your_github_app_id
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Set to false ONLY for local testing without a real GitHub App signature.
VERIFY_GITHUB_SIGNATURE=true

# ── AI / LLM (plug into _analyse_file() in impact_analysis.py) ───────────────
GOOGLE_API_KEY=your_google_api_key

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
