# GitHub App webhook secret (from GitHub App settings)
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Set to false only for local testing without signature (never in production)
VERIFY_GITHUB_SIGNATURE=true

# Kafka / Redpanda (default matches docker-compose). Use KAFKA_ENABLED=false if no broker (e.g. smoke deploy).
KAFKA_ENABLED=true
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC_GITHUB=github-events
KAFKA_TOPIC_DLQ=github-events-dlq
KAFKA_GROUP_ID=impact-worker

# Redis
REDIS_URL=redis://localhost:6379/0

# PostgreSQL (default matches docker-compose)
DATABASE_URL=postgresql://app:app@localhost:5432/app
